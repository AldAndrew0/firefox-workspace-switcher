{
  "manifest_version": 3,
  "name": "Workspace Tab Master",
  "version": "2.0",
  "description": "Organizza le schede in aree di lavoro. Passa da lavoro a svago in un clic, con supporto ai gruppi nativi di Firefox.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "theme"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "html/popup.html",
    "default_title": "Workspace Tab Master"
  },
  "options_ui": {
    "page": "html/options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "js/modules/storage-api.js",
      "js/pages/background.js"
    ]
  }
}