{
  "manifest_version": 3,
  "name": "Workspace Tab Master",
  "version": "1.1",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sessions",
    "browserSettings"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background/background.js"]
  }
}